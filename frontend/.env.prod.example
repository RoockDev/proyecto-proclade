# Variables del frontend en PRODUCCIÓN.
# Vite las "embebe" en el bundle durante `yarn build`, así que se aplican en
# tiempo de compilación de la imagen Docker. Copia este fichero a
# frontend/.env antes de construir la imagen de producción.

# Todo va a través de Nginx en el mismo origen, así que basta con una ruta
# relativa para la API y el socket.
VITE_API_BASE_URL=/api
VITE_SOCKET_PATH=
