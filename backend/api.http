@baseUrl = http://localhost:3000
@adminEmail = admin@demo.com
@userEmail = usuario@demo.com
@validPasswordUser = 123456  
@validPasswordAdmin = admin123       
@invalidPassword = 1234567
@unknownEmail = noexiste@test.com

### LOGIN OK - admin (200)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{validPasswordAdmin}}"
}

### LOGIN OK - user (200)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{validPasswordUser}}"
}

### LOGIN FAIL - wrong password (401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{invalidPassword}}"
}

### LOGIN FAIL - unknown email (401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{unknownEmail}}",
  "password": "{{validPasswordUser}}"
}

### LOGIN FAIL - invalid payload: password too short (400)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "123"
}

### LOGIN FAIL - invalid payload: bad email format (400)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "email-invalido",
  "password": "{{validPasswordUser}}"
}

### ─── FORGOT PASSWORD ───────────────────────────────────

### FORGOT PASSWORD OK - usuario local existente (200, mensaje genérico)
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "{{userEmail}}"
}

### FORGOT PASSWORD - email inexistente (200, mismo mensaje genérico por seguridad)
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "{{unknownEmail}}"
}

### FORGOT PASSWORD FAIL - email vacío (400)
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": ""
}

### FORGOT PASSWORD FAIL - formato inválido (400)
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "email-invalido"
}

### ─── RESET PASSWORD ────────────────────────────────────

### RESET PASSWORD FAIL - token inválido (400)
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "token-invalido-o-expirado",
  "newPassword": "NuevaPass123!"
}

### RESET PASSWORD FAIL - contraseña muy corta (400)
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "algun-token",
  "newPassword": "123"
}

### RESET PASSWORD FAIL - campos vacíos (400)
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "",
  "newPassword": ""
}
