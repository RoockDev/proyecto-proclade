generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // NO url aquí en Prisma 7 - se define en prisma.config.ts
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

enum SuperheroStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

model User {
  id                       Int       @id @default(autoincrement())
  email                    String    @unique
  passwordHash             String
  name                     String
  surname                  String
  google                   Boolean   @default(false)
  resetPasswordTokenHash   String?
  resetPasswordExpiresAt   DateTime?
  deletedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  roles                    Role[]    @relation("UserRoles")
  createdNews              News[]
  createdSuperheroes       Superhero[]
}


model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  users     User[]   @relation("UserRoles")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  excerpt     String
  content     String     @db.Text
  imageUrl    String?
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  createdById Int
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])
}

model Superhero {
  id          Int             @id @default(autoincrement())
  name        String
  slug        String          @unique
  description String          @db.Text
  quote       String?
  country     String?
  imageUrl    String?
  sortOrder   Int             @default(0)
  status      SuperheroStatus @default(DRAFT)
  createdById Int
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])
}
