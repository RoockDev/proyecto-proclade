DATABASE_URL="postgresql://dev:devpass@db:5432/appdb"

CORS_ORIGIN=

# Obligatorio: usa un valor largo, aleatorio y privado en cada entorno.
JWT_SECRET=
JWT_EXPIRES_IN=1d

# ─── Admin inicial del sistema ───
SYSTEM_ADMIN_EMAIL=admin@equipo-puch.local
# Minimo 8 caracteres, una mayuscula, una minuscula y un numero
SYSTEM_ADMIN_PASSWORD=CambiaEsta123!
SYSTEM_ADMIN_NAME=Administrador
SYSTEM_ADMIN_SURNAME=Equipo PUCH

# ─── SMTP (Gmail) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@fundacionproclade.org
SMTP_PASS=
MAIL_FROM=info@fundacionproclade.org
CONTACT_FORM_TO=info@fundacionproclade.org

# ─── Password Reset ───
FRONTEND_URL=http://localhost
RESET_PASSWORD_TTL_MINUTES=30

# ─── Chatbot matching (HU-40) ───
CHATBOT_WEIGHT_KEYWORD=0.35
CHATBOT_WEIGHT_FUZZY=0.25
CHATBOT_WEIGHT_SEMANTIC=0.30
CHATBOT_WEIGHT_CONTEXT=0.10
CHATBOT_THRESHOLD_DIRECT_ANSWER=0.56
CHATBOT_THRESHOLD_CLARIFICATION=0.38
CHATBOT_FUZZY_INTERNAL_MIN=0.25
