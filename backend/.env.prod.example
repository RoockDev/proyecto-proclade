# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — BACKEND en PRODUCCIÓN
# Copia este fichero a backend/.env y rellena los valores reales antes de
# arrancar con `docker compose -f docker-compose.prod.yml up -d --build`.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base de datos ───
# Las credenciales deben coincidir con POSTGRES_USER/PASSWORD/DB del .env raíz.
# El host es `db` (nombre del servicio en docker-compose.prod.yml).
DATABASE_URL="postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@db:5432/CHANGE_ME_DB"

# ─── CORS ───
# En producción todo va por Nginx en el mismo origen, así que normalmente
# basta con dejarlo apuntando al dominio público (o vacío si no aplica).
CORS_ORIGIN=https://tu-dominio.example.com

# ─── JWT ───
# OBLIGATORIO. Usa una cadena larga y aleatoria (mínimo 32 caracteres).
# Generar con: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=1d

# ─── Google Sign-In (opcional) ───
GOOGLE_CLIENT_ID=

# ─── SMTP (Gmail) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=proclade.pass@gmail.com
SMTP_PASS=
MAIL_FROM=proclade.pass@gmail.com

# ─── Password Reset ───
# URL pública del frontend para componer los enlaces enviados por email.
FRONTEND_URL=https://tu-dominio.example.com
RESET_PASSWORD_TTL_MINUTES=30

# ─── Administrador inicial del sistema ───
# Creado/actualizado automáticamente por `yarn prisma:init-system` al arrancar.
# CAMBIA la contraseña tras el primer acceso.
SYSTEM_ADMIN_EMAIL=admin@tu-dominio.example.com
# Mínimo 8 caracteres, una mayúscula, una minúscula y un número.
SYSTEM_ADMIN_PASSWORD=
SYSTEM_ADMIN_NAME=Administrador
SYSTEM_ADMIN_SURNAME=Proclade
